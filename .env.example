# Server
PORT=4173
NDR_DATA_DIR=.ndr-data
NDR_API_KEY=change-me-for-shared-environments
NDR_MAX_BODY_BYTES=1048576
NDR_RATE_LIMIT_WINDOW_MS=60000
NDR_RATE_LIMIT_MAX=120
NDR_RETAIN_RUNS=50
NDR_AUDIT_RETENTION_DAYS=2555
NDR_EVIDENCE_BUCKET=
NDR_EVIDENCE_PREFIX=signalprism/evidence-packages
NDR_EVIDENCE_REGION=us-east-1
NDR_EVIDENCE_RETENTION_DAYS=90
NDR_EVIDENCE_OBJECT_LOCK_MODE=GOVERNANCE

# Persistence
# local keeps tenant metadata, jobs, runs, audit, and local evidence packages under NDR_DATA_DIR.
# dynamodb stores tenant metadata, jobs, runs, and audit records in the configured table.
NDR_STORE=local
NDR_DDB_TABLE=
NDR_DDB_REGION=us-east-1

# OIDC/SSO
NDR_OIDC_ISSUER=
NDR_OIDC_AUDIENCE=
NDR_OIDC_JWKS_URI=
NDR_OIDC_CLIENT_ID=
NDR_OIDC_CLIENT_SECRET=
NDR_OIDC_REDIRECT_URI=http://localhost:4173/
NDR_OIDC_SCOPES=openid profile email groups
NDR_ADMIN_GROUP=ndr-admin
NDR_ANALYST_GROUP=ndr-analyst
NDR_VIEWER_GROUP=ndr-viewer
NDR_DEFAULT_TENANT=default
NDR_TENANT_CLAIM=tenant_id

# AWS Bedrock AI assistant
NDR_BEDROCK_ENABLED=false
NDR_BEDROCK_REGION=us-east-1
NDR_BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
NDR_BEDROCK_MAX_TOKENS=900
NDR_BEDROCK_TEMPERATURE=0.2
NDR_BEDROCK_MAX_CONTEXT_CHARS=24000

# AWS ingest credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
